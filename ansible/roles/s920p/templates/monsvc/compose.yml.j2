services:
  beszel_agent:
    deploy:
      replicas: 1
    environment:
      HUB_URL: https://up.replo.de
      KEY: {{ secrets.beszel.pub_key }}
      LISTEN: "45876"
      TOKEN: {{ secrets.beszel.s920p_token }}
    image: henrygd/beszel-agent:0.18.7
    labels:
      io.portainer.accesscontrol.teams: operators
      traefik.enable: "false"
    network_mode: host
    restart: unless-stopped
    volumes:
      - type: bind
        source: /var/run/docker.sock
        target: /var/run/docker.sock
        read_only: true
      - type: bind
        source: /
        target: /extra-filesystems/root__md0
        read_only: true
      - type: bind
        source: /volume1
        target: /extra-filesystems/volume1__volume1
        read_only: true
  diun:
    deploy:
      replicas: 1
    environment:
      DIUN_DEFAULTS_EXCLUDETAGS: ^\w+$
      DIUN_DEFAULTS_INCLUDETAGS: ^v?\d+\.\d+(\.\d+)?$
      DIUN_DEFAULTS_MAXTAGS: "1"
      DIUN_DEFAULTS_SORTTAGS: semver
      DIUN_DEFAULTS_WATCHREPO: "true"
      DIUN_NOTIF_MAIL_FROM: noreply@replo.de
      DIUN_NOTIF_MAIL_HOST: smtp-relay.brevo.com
      DIUN_NOTIF_MAIL_PASSWORD: {{ secrets.brevo.smtp_password }}
      DIUN_NOTIF_MAIL_PORT: "587"
      DIUN_NOTIF_MAIL_SSL: "false"
      DIUN_NOTIF_MAIL_TEMPLATEBODY: |
        {% raw %}Docker tag {{ if .Entry.Image.HubLink }}[**{{ .Entry.Image }}**]({{ .Entry.Image.HubLink }}){{ else }}**{{ .Entry.Image }}**{{ end }}
        which you subscribed to through {{ .Entry.Provider }} provider {{ if (eq .Entry.Status "new") }}is available{{ else }}has been updated{{ end }}
        on **{{ .Entry.Image.Domain }}** registry (triggered by _{{ escapeMarkdown .Meta.Hostname }}_ host).

        This image has been {{ if (eq .Entry.Status "new") }}created{{ else }}updated{{ end }} at
        <code>{{ .Entry.Manifest.Created.Format "Jan 02, 2006 15:04:05 UTC" }}</code> with digest <code>{{ .Entry.Manifest.Digest }}</code>
        for <code>{{ .Entry.Manifest.Platform }}</code> platform.{% endraw %}

      DIUN_NOTIF_MAIL_TEMPLATETITLE: |
        {% raw %}{{ .Entry.Image }} {{ if (eq .Entry.Status "new") }}is available{{ else }}has been updated{{ end }}{% endraw %}

      DIUN_NOTIF_MAIL_TO: root@replo.de
      DIUN_NOTIF_MAIL_USERNAME: {{ secrets.brevo.smtp_username }}
      DIUN_PROVIDERS_DOCKER: "true"
      DIUN_PROVIDERS_DOCKER_WATCHBYDEFAULT: "true"
      DIUN_WATCH_FIRSTCHECKNOTIF: "true"
      DIUN_WATCH_JITTER: 30s
      DIUN_WATCH_SCHEDULE: 0 */6 * * *
      DIUN_WATCH_WORKERS: "20"
      TZ: Europe/Berlin
    hostname: s920p
    image: crazymax/diun:4.31.0
    labels:
      io.portainer.accesscontrol.teams: operators
      traefik.enable: "false"
    restart: unless-stopped
    volumes:
      - type: bind
        source: /var/run/docker.sock
        target: /var/run/docker.sock
        read_only: true
      - type: bind
        source: /volume2/var/diun
        target: /data
  dozzle_agent:
    command:
      - agent
    deploy:
      replicas: 1
    environment:
      DOZZLE_NO_ANALYTICS: "true"
    hostname: s920p
    image: amir20/dozzle:v10.5.0
    labels:
      io.portainer.accesscontrol.teams: operators
      traefik.enable: "false"
    networks:
      netsvc: {}
    ports:
      - target: 7007
        published: "7007"
        protocol: tcp
    restart: unless-stopped
    volumes:
      - type: bind
        source: /var/run/docker.sock
        target: /var/run/docker.sock
        read_only: true
  portainer_agent:
    deploy:
      replicas: 1
    environment:
      DEBUG: "0"
      EDGE: "1"
      EDGE_ID: {{ secrets.portainer.s920p_edge_id }}
      EDGE_INSECURE_POLL: "1"
      EDGE_KEY: {{ secrets.portainer.s920p_edge_key }}
      LOG_LEVEL: INFO
    image: portainer/agent:2.40.0-alpine
    labels:
      io.portainer.accesscontrol.teams: operators
      traefik.enable: "false"
    restart: unless-stopped
    volumes:
      - type: bind
        source: /var/run/docker.sock
        target: /var/run/docker.sock
        read_only: true
      - type: bind
        source: /volume2/var/portainer
        target: /data
networks:
  netsvc:
    name: netsvc
    external: true

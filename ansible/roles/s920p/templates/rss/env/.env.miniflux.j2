BASE_URL=https://rss.replo.de
DATABASE_URL=postgres://miniflux:{{ secrets.miniflux.database_password }}@pg/miniflux?sslmode=disable
FETCHER_ALLOW_PRIVATE_NETWORKS="1"
INTEGRATION_ALLOW_PRIVATE_NETWORKS="1"
OAUTH2_CLIENT_ID={{ secrets.miniflux.oauth_client_id }}
OAUTH2_CLIENT_SECRET={{ secrets.miniflux.oauth_client_secret }}
OAUTH2_OIDC_DISCOVERY_ENDPOINT=https://id.replo.de
OAUTH2_PROVIDER=oidc
OAUTH2_REDIRECT_URL=https://rss.replo.de/oauth2/oidc/callback
OAUTH2_USER_CREATION="1"
RUN_MIGRATIONS="1"
